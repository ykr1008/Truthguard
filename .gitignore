# ========================
# TruthGuard .gitignore
# ========================

# 1. API Keys and Secrets (CRITICAL)
.env
*.env

# 2. Virtual Environments
venv/
env/
.venv/

# 3. Python Cache
__pycache__/
*.pyc
*.pyo
*.pyd

# 4. OS & Editor Settings
.vscode/
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 5. Generated Outputs & Logs
# Ignores generated markdown reports but keeps the folder structure
backend/reports/*.md
!backend/reports/.gitkeep
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 6. React Frontend (Vite)
node_modules/
dist/
dist-ssr/
*.local