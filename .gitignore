# ========================
# TruthGuard .gitignore
# ========================

# 1. API Keys and Secrets (CRITICAL)
.env
*.env

# 2. Virtual Environments
venv/
env/
.venv/

# 3. Python Cache
__pycache__/
*.pyc
*.pyo
*.pyd

# 4. OS & Editor Settings
.vscode/
.DS_Store

# 5. Generated Outputs & Logs
# Ignores all generated markdown reports but keeps the folder structure
backend/reports/*.md
!backend/reports/.gitkeep
*.log

# 6. React Frontend (Vite)
node_modules/
dist/
dist-ssr/
*.local